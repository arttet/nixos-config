{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixos-config.local/schemas/disko-state.v1.schema.json",
  "title": "NixOS Config disko state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "disk"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "disk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device"],
      "properties": {
        "device": {
          "type": "string",
          "pattern": "^/dev/[A-Za-z0-9/._-]+$"
        }
      }
    },
    "luks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passwordFile"],
      "properties": {
        "passwordFile": {
          "type": "string",
          "pattern": "^/[^\\u0000]*$"
        }
      }
    }
  }
}
