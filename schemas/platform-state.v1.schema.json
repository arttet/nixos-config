{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixos-config.local/schemas/platform-state.v1.schema.json",
  "title": "NixOS Config platform state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "host", "users"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname", "timezone"],
      "properties": {
        "hostname": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,62}$"
        },
        "timezone": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_+.-]+(/[A-Za-z0-9_+.-]+)*$"
        }
      }
    },
    "homelab": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lanCidr", "storage"],
      "properties": {
        "lanCidr": {
          "$ref": "#/$defs/ipv4Cidr"
        },
        "domain": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*[A-Za-z0-9]$"
        },
        "lanInterface": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]+$"
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["luksDevice", "mapperName", "fileSystemType"],
          "properties": {
            "luksDevice": {
              "type": "string",
              "pattern": "^/dev/disk/by-uuid/[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$"
            },
            "mapperName": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,126}$"
            },
            "fileSystemType": {
              "type": "string",
              "enum": ["btrfs", "ext4", "xfs"]
            }
          }
        },
        "services": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "wireguard": { "type": "boolean" },
            "adguard": { "type": "boolean" },
            "beszel": { "type": "boolean" },
            "caddy": { "type": "boolean" },
            "forgejo": { "type": "boolean" },
            "forgejoRunner": { "type": "boolean" },
            "samba": { "type": "boolean" },
            "iperf3": { "type": "boolean" },
            "podman": { "type": "boolean" },
            "openspeedtest": { "type": "boolean" }
          }
        },
        "forgejo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*[A-Za-z0-9]$"
            },
            "runnerEnvironmentFile": {
              "$ref": "#/$defs/absolutePath"
            }
          }
        },
        "openspeedtest": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*[A-Za-z0-9]$"
            }
          }
        },
        "beszel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*[A-Za-z0-9]$"
            },
            "agentEnvironmentFile": {
              "$ref": "#/$defs/absolutePath"
            }
          }
        },
        "adguard": {
          "type": "object",
          "additionalProperties": false,
          "required": ["upstreamDns"],
          "properties": {
            "upstreamDns": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "users": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "sources"],
        "anyOf": [
          { "required": ["hashedPasswordFile"] },
          { "required": ["authorizedKeysFile"] }
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_-]*$",
            "not": {
              "const": "root"
            }
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9 ._-]+$"
          },
          "hashedPasswordFile": {
            "type": "string",
            "pattern": "^/[^\\u0000]*$"
          },
          "authorizedKeysFile": {
            "type": "string",
            "pattern": "^/[^\\u0000]*$"
          },
          "isAdmin": {
            "type": "boolean"
          },
          "extraGroups": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]*$"
            },
            "uniqueItems": true
          },
          "shell": {
            "enum": ["bash", "nushell", "zsh"]
          },
          "homeStateVersion": {
            "type": "string",
            "pattern": "^[0-9]{2}\\.[0-9]{2}$"
          },
          "sources": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["dotfiles", "dotfilesRoot"],
                "properties": {
                  "dotfiles": {
                    "type": "string",
                    "pattern": "^/[^\\u0000]*$"
                  },
                  "dotfilesModule": {
                    "oneOf": [
                      {
                        "type": "null"
                      },
                      {
                        "type": "string",
                        "pattern": "^/[^\\u0000]*$"
                      }
                    ]
                  },
                  "dotfilesRoot": {
                    "type": "string",
                    "pattern": "^/[^\\u0000]*$"
                  },
                  "links": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^(?!/)(?!.*\\.\\.)[^\\u0000]+$"
                    },
                    "uniqueItems": true
                  }
                }
              }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "absolutePath": {
      "type": "string",
      "pattern": "^/[^\\u0000]*$"
    },
    "ipv4Cidr": {
      "type": "string",
      "pattern": "^((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])/([0-9]|[12][0-9]|3[0-2])$"
    },
    "ipv6Cidr": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f:]+/([0-9]|[1-9][0-9]|1[01][0-9]|12[0-8])$"
    }
  }
}
