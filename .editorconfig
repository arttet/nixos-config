root = true

# Defaults for every file in the repo
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Data / config formats
[*.{toml,yml,yaml}]
indent_size = 2

# Markdown — trailing whitespace is significant (hard line breaks);
# code blocks may contain arbitrary indentation (diff output, etc.)
[*.md]
trim_trailing_whitespace = false
indent_size = unset

# Justfile — recipe bodies use the indentation just expects
[Justfile]
indent_size = 4
